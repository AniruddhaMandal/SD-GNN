{
  "dataset_name": "COLLAB",
  "model_name": "ARCH-6",
  "task": "Multi-Class-Classification",

  "model_config": {
    "mpnn_type": "gine",
    "node_feature_dim": 128,
    "edge_feature_dim": 0,
    "hidden_dim": 128,
    "mpnn_layers": 8,
    "dropout": 0.0,
    "out_dim": 3,
    "pooling": "sum",
    "temperature": 0.5,
    "subgraph_sampling": true,
    "subgraph_param": { "k": 10, "m": 4, "pooling": "mean" },
    "kwargs": {
      "sub_layers": 4,
      "global_layers": 4,
      "num_heads": 8,
      "ffn_dim": 256,
      "aggregator": "weighted_mean",
      "use_edge_bias": false,
      "init_mode": "add",
      "node_feature_type": "degree_embed",
      "max_degree": 100
    }
  },

  "train": {
    "epochs": 150,
    "train_batch_size": 32,
    "val_batch_size": 64,
    "lr": 2e-4,
    "weight_decay": 1e-5,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 20,
      "factor": 0.5
    },
    "loss_fn": "CrossEntropyLoss",
    "metric": "ACC",
    "grad_clip": 1.0
  },

  "device": "cuda",
  "seed": 42,
  "num_workers": 2,
  "save_every": 5,
  "keep_last_k": 3,
  "sampler": "graphlet"
}
