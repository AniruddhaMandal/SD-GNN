{
  "dataset_name": "ZINC",
  "model_name": "ARCH-6",
  "task": "Regression",

  "model_config": {
    "mpnn_type": "gine",
    "node_feature_dim": 28,
    "edge_feature_dim": 4,
    "hidden_dim": 128,
    "mpnn_layers": 8,
    "dropout": 0.1,
    "out_dim": 1,
    "pooling": "sum",
    "temperature": 0.5,
    "subgraph_sampling": true,
    "subgraph_param": { "k": 10, "m": 6, "pooling": "mean" },
    "kwargs": {
      "sub_layers": 4,
      "global_layers": 4,
      "num_heads": 8,
      "ffn_dim": 256,
      "aggregator": "mean",
      "use_edge_bias": true,
      "init_mode": "add"
    }
  },

  "train": {
    "epochs": 500,
    "train_batch_size": 1024,
    "val_batch_size": 64,
    "lr": 1e-3,
    "weight_decay": 0.0,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 30,
      "factor": 0.5
    },
    "loss_fn": "L1Loss",
    "metric": "MAE",
    "grad_clip": 1.0
  },

  "device": "cuda",
  "seed": 42,
  "num_workers": 2,
  "save_every": 10,
  "keep_last_k": 3,
  "sampler": "graphlet"
}
