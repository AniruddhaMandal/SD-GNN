{
  "dataset_name": "ZINC",
  "model_name": "ARCH-20",
  "task": "Regression",

  "model_config": {
    "mpnn_type": "gine",
    "node_feature_dim": 21,
    "edge_feature_dim": 3,
    "hidden_dim": 128,
    "mpnn_layers": 0,
    "dropout": 0.0,
    "out_dim": 1,
    "pooling": "sum",
    "subgraph_sampling": true,
    "subgraph_param": { "k": 10, "m": 32 },
    "kwargs": {
      "gnn_layers": 6,
      "mlp_layers": 2,
      "rwse_steps": 16
    }
  },

  "train": {
    "epochs": 1000,
    "train_batch_size": 64,
    "val_batch_size": 64,
    "lr": 1e-3,
    "weight_decay": 1e-5,
    "optimizer": "adamw",
    "scheduler": {
      "type": "cosine_warmup",
      "warmup_epochs": 50,
      "eta_min": 1e-6
    },
    "loss_fn": "L1Loss",
    "metric": "MAE",
    "grad_clip": 1.0
  },

  "device": "cuda",
  "seed": 42,
  "num_workers": 4,
  "save_every": 20,
  "keep_last_k": 3,
  "sampler": "graphlet"
}
