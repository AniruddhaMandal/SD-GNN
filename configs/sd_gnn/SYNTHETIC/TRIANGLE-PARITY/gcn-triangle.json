{
  "name": "SYN: Parity-Triangle SD-GNN GCN",
  "dataset_name": "Triangle-Parity",
  "model_name": "SD-GNN",
  "task": "Binary-Classification",
  "model_config": {
    "mpnn_type": "gcn",
    "node_feature_dim": 64,
    "hidden_dim": 128,
    "mpnn_layers": 3,
    "dropout": 0.1,
    "out_dim": 2,
    "pooling": "mean",
    "temperature": 5.0,
    "subgraph_sampling": true,
    "subgraph_param": {
      "k": 3,
      "m": 20,
      "pooling": "sum"
    },
    "kwargs": {
      "node_feature_type": "degree_embed",
      "max_degree": 64,
      "aggregator": "attention",
      "sub_num_layers": 2,
      "val_ema_alpha": 0.85
    }
  },
  "train": {
    "epochs": 50,
    "train_batch_size": 50,
    "val_batch_size": 25,
    "train_ratio": 0.6,
    "val_ratio": 0.2,
    "lr": 0.001,
    "weight_decay": 0.0005,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 10
    },
    "loss_fn": "CrossEntropyLoss",
    "metric": "ACC",
    "grad_clip": 1.0
  },
  "device": "cuda",
  "seed": 42,
  "num_workers": 4,
  "log_dir": "logs",
  "checkpoint_dir": "checkpoints/ss-triangle/",
  "save_every": 1,
  "keep_last_k": 3,
  "use_amp": true,
  "grad_clip": 2.0,
  "sampler": "uniform"
}
