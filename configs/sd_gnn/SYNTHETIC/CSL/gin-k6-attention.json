{
  "name": "CSL: SD-GNN (k=6, attention, GIN)",
  "dataset_name": "CSL",
  "model_name": "SD-GNN",
  "task": "Multi-Class-Classification",
  "model_config": {
    "mpnn_type": "gin",
    "node_feature_dim": 8,
    "hidden_dim": 64,
    "mpnn_layers": 5,
    "dropout": 0.0,
    "out_dim": 10,
    "pooling": "mean",
    "temperature": 0.5,
    "subgraph_sampling": true,
    "subgraph_param": {
      "k": 6,
      "m": 6,
      "pooling": "sum"
    },
    "kwargs": {
      "node_feature_type": "lap_pe",
      "lap_pe_dim": 8,
      "aggregator": "attention",
      "sub_num_layers": 4,
      "val_ema_alpha": 0.85
    }
  },
  "train": {
    "epochs": 100,
    "train_batch_size": 10,
    "val_batch_size": 10,
    "train_ratio": 0.8,
    "val_ratio": 0.1,
    "lr": 0.001,
    "weight_decay": 1e-05,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 20
    },
    "loss_fn": "CrossEntropyLoss",
    "metric": "ACC",
    "grad_clip": 1.0
  },
  "device": "cuda",
  "seed": 42,
  "num_workers": 0,
  "log_dir": "logs",
  "checkpoint_dir": "checkpoints/ss-csl-k6-notebook-match/",
  "sampler": "uniform",
  "use_amp": false,
  "tracker": "wandb"
}
