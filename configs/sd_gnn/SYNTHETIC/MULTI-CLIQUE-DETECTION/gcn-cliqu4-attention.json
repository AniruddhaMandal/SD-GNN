{
  "name": "Multi-Clique-Detection: SD-GNN GCN",
  "dataset_name": "Multi-Clique-Detection",
  "model_name": "SD-GNN",
  "task": "Multi-Classification",
  "model_config": {
    "mpnn_type": "gcn",
    "node_feature_dim": 64,
    "hidden_dim": 128,
    "mpnn_layers": 5,
    "dropout": 0.2,
    "out_dim": 4,
    "pooling": "mean",
    "temperature": 0.2,
    "subgraph_sampling": true,
    "subgraph_param": {
      "k": 5,
      "m": 8,
      "pooling": "sum"
    },
    "kwargs": {
      "node_feature_type": "degree_embed",
      "max_degree": 64,
      "aggregator": "attention",
      "sub_num_layers": 4,
      "val_ema_alpha": 0.85
    }
  },
  "train": {
    "epochs": 100,
    "train_batch_size": 32,
    "val_batch_size": 32,
    "train_ratio": 0.6,
    "val_ratio": 0.2,
    "lr": 0.001,
    "weight_decay": 0.0005,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 15
    },
    "loss_fn": "CrossEntropyLoss",
    "metric": "ACC",
    "grad_clip": 1.0
  },
  "device": "cuda",
  "seed": 42,
  "num_workers": 4,
  "log_dir": "logs",
  "checkpoint_dir": "checkpoints/ss-multi-clique/",
  "save_every": 10,
  "keep_last_k": 3,
  "use_amp": true,
  "grad_clip": 2.0,
  "sampler": "uniform"
}
