{
  "name": "SD-GNN: MolHIV GIN Attention",
  "dataset_name": "molhiv",
  "model_name": "SD-GNN",
  "task": "Binary-Classification",
  "model_config": {
    "mpnn_type": "gin",
    "node_feature_dim": 64,
    "edge_feature_dim": 64,
    "hidden_dim": 300,
    "mpnn_layers": 5,
    "dropout": 0.3,
    "out_dim": 1,
    "pooling": "mean",
    "temperature": 10.0,
    "subgraph_sampling": true,
    "subgraph_param": {
      "k": 8,
      "m": 6,
      "pooling": "sum"
    },
    "kwargs": {
      "aggregator": "attention",
      "sub_num_layers": 4,
      "val_ema_alpha": 0.85
    }
  },
  "train": {
    "epochs": 100,
    "train_batch_size": 32,
    "val_batch_size": 64,
    "lr": 0.001,
    "weight_decay": 1e-05,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 10,
      "factor": 0.5
    },
    "loss_fn": "BCEWithLogitsLoss",
    "metric": "ROCAUC",
    "grad_clip": 1.0
  },
  "device": "cuda",
  "seed": 42,
  "num_workers": 4,
  "log_dir": "logs/OGB/molhiv/",
  "checkpoint_dir": "checkpoints",
  "save_every": 10,
  "keep_last_k": 3,
  "use_amp": false,
  "grad_clip": 1.0
}
