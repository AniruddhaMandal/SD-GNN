{
  "name": "SD-GNN: Peptides-func SS GINE",
  "dataset_name": "Peptides-func",
  "model_name": "SD-GNN",
  "task": "Multi-Lable-Binary-Classification",
  "model_config": {
    "mpnn_type": "gine",
    "node_feature_dim": 9,
    "edge_feature_dim": 3,
    "hidden_dim": 300,
    "mpnn_layers": 5,
    "dropout": 0.1,
    "out_dim": 10,
    "pooling": "mean",
    "subgraph_sampling": true,
    "subgraph_param": {
      "k": 5,
      "m": 6,
      "pooling": "mean"
    },
    "kwargs": {
      "aggregator": "mean",
      "sub_num_layers": 4,
      "val_ema_alpha": 0.85
    }
  },
  "train": {
    "epochs": 50,
    "train_batch_size": 64,
    "val_batch_size": 64,
    "lr": 0.001,
    "weight_decay": 1e-05,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 20
    },
    "loss_fn": "BCEWithLogitsLoss",
    "metric": "AP",
    "grad_clip": 1.0
  },
  "device": "cuda",
  "seed": 42,
  "num_workers": 4,
  "log_dir": "logs",
  "checkpoint_dir": "checkpoints",
  "save_every": 1,
  "keep_last_k": 3,
  "use_amp": false,
  "grad_clip": 2.0
}
