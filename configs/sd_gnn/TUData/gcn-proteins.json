{
  "name": "SD-GNN: PROTEINS GCN",
  "dataset_name": "PROTEINS",
  "model_name": "SD-GNN",
  "task": "Binary-Classification",
  "model_config": {
    "mpnn_type": "gin",
    "node_feature_dim": 4,
    "hidden_dim": 128,
    "mpnn_layers": 3,
    "dropout": 0.2,
    "out_dim": 2,
    "pooling": "mean",
    "transformer_num_heads": 32,
    "transformer_num_layers": 8,
    "temperature": 0.005,
    "subgraph_sampling": true,
    "subgraph_param": {
      "k": 6,
      "m": 6,
      "pooling": "sum"
    },
    "kwargs": {
      "aggregator": "weighted_mean",
      "sub_num_layers": 2,
      "val_ema_alpha": 0.85
    }
  },
  "train": {
    "epochs": 100,
    "train_batch_size": 32,
    "val_batch_size": 32,
    "train_ratio": 0.7,
    "val_ratio": 0.15,
    "lr": 0.001,
    "weight_decay": 1e-05,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 20
    },
    "loss_fn": "CrossEntropyLoss",
    "metric": "ACC",
    "grad_clip": 1.0
  },
  "device": "cuda",
  "seed": 42,
  "num_workers": 4,
  "log_dir": "logs/phase1",
  "checkpoint_dir": "checkpoints",
  "save_every": 10,
  "keep_last_k": 3,
  "use_amp": false,
  "grad_clip": 2.0,
  "sampler": "graphlet"
}
