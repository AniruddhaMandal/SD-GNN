{
  "name": "SD-GNN: COLLAB GCN",
  "dataset_name": "COLLAB",
  "model_name": "SD-GNN",
  "task": "Multi-Class-Classification",
  "model_config": {
    "mpnn_type": "gcn",
    "node_feature_type": "degree_embed",
    "max_degree": 500,
    "node_feature_dim": 64,
    "hidden_dim": 128,
    "mpnn_layers": 4,
    "dropout": 0.3,
    "out_dim": 3,
    "pooling": "mean",
    "temperature": 0.5,
    "subgraph_sampling": true,
    "subgraph_param": {
      "k": 8,
      "m": 4,
      "pooling": "mean"
    },
    "kwargs": {
      "aggregator": "mean",
      "sub_num_layers": 3,
      "val_ema_alpha": 0.85
    }
  },
  "train": {
    "epochs": 50,
    "train_batch_size": 32,
    "val_batch_size": 32,
    "lr": 1e-3,
    "weight_decay": 5e-4,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 10
    },
    "loss_fn": "CrossEntropyLoss",
    "metric": "ACC",
    "grad_clip": 1.0
  },
  "device": "cuda",
  "seed": 42,
  "num_workers": 4,
  "log_dir": "logs",
  "checkpoint_dir": "checkpoints",
  "save_every": 5,
  "keep_last_k": 3,
  "use_amp": false,
  "sampler": "graphlet"
}
