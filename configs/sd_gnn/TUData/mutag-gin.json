{
  "name": "SD-GNN: MUTAG GIN",
  "dataset_name": "MUTAG",
  "model_name": "SD-GNN",
  "task": "Multi-Class-Classification",
  "model_config": {
    "mpnn_type": "gin",
    "node_feature_dim": 7,
    "hidden_dim": 64,
    "mpnn_layers": 4,
    "dropout": 0.1,
    "out_dim": 2,
    "pooling": "mean",
    "temperature": 0.5,
    "subgraph_sampling": true,
    "subgraph_param": { "k": 5, "m": 6, "pooling": "mean" },
    "kwargs": { "aggregator": "mean", "sub_num_layers": 3, "val_ema_alpha": 0.85 }
  },
  "train": {
    "epochs": 100,
    "train_batch_size": 32,
    "val_batch_size": 64,
    "lr": 1e-3,
    "weight_decay": 1e-5,
    "optimizer": "adam",
    "scheduler": {
        "type":"reduce_on_plateau",
        "patience":20
    },
    "loss_fn": "CrossEntropyLoss",
    "metric": "ACC",
    "grad_clip": 1.0
  },
  "device": "cuda",
  "seed": 42,
  "sampler": "graphlet"
}
