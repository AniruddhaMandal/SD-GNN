{
  "dataset_name": "IMDB-BINARY",
  "model_name": "ARCH-24",
  "task": "Binary-Classification",

  "model_config": {
    "mpnn_type": "gine",
    "node_feature_dim": 64,
    "edge_feature_dim": 64,
    "hidden_dim": 64,
    "mpnn_layers": 4,
    "dropout": 0.2,
    "out_dim": 1,
    "pooling": "sum",
    "subgraph_sampling": true,
    "subgraph_param": { "k": 6, "m": 16, "m_eval": 16, "pooling": "mean" },
    "kwargs": {
      "mlp_layers": 2,
      "num_heads": 4,
      "use_ht_pool": false,
      "use_ht_inter": false,
      "node_feature_type": "degree_embed",
      "max_degree": 135
    }
  },

  "train": {
    "epochs": 150,
    "train_batch_size": 32,
    "val_batch_size": 32,
    "train_ratio": 0.7,
    "val_ratio": 0.15,
    "lr": 1e-3,
    "weight_decay": 5e-4,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 20,
      "factor": 0.5
    },
    "loss_fn": "BCEWithLogitsLoss",
    "metric": "ACC",
    "grad_clip": 1.0
  },

  "device": "cuda",
  "seed": 42,
  "num_workers": 4,
  "save_every": 10,
  "keep_last_k": 3,
  "sampler": "graphlet"
}
