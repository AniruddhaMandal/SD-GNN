{
  "dataset_name": "SR25-0",
  "model_name": "ARCH-24",
  "task": "Binary-Classification",
  "raw_dir": "data/BREC/raw",

  "model_config": {
    "mpnn_type": "gine",
    "node_feature_dim": 2,
    "edge_feature_dim": 1,
    "hidden_dim": 64,
    "mpnn_layers": 4,
    "dropout": 0.0,
    "out_dim": 2,
    "pooling": "sum",
    "subgraph_sampling": true,
    "subgraph_param": { "k": 13, "m": 64, "m_eval": 64, "pooling": "mean" },
    "kwargs": {
      "mlp_layers": 2,
      "num_heads": 4,
      "use_inter_conv": true,
      "use_ht_pool": true,
      "use_ht_inter": true,
      "use_bfs_pe": true,
      "use_logp_pe": false,
      "node_feature_type": "all_one"
    }
  },

  "train": {
    "epochs": 100,
    "train_batch_size": 16,
    "val_batch_size": 16,
    "lr": 1e-3,
    "weight_decay": 0.0,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 20,
      "factor": 0.5
    },
    "loss_fn": "CrossEntropyLoss",
    "metric": "ACC"
  },

  "device": "cuda",
  "seed": 42,
  "num_workers": 0,
  "sampler": "graphlet"
}
