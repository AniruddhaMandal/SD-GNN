{
  "dataset_name": "molhiv",
  "model_name": "ARCH-7-V2",
  "task": "Binary-Classification",

  "model_config": {
    "mpnn_type": "gine",
    "node_feature_dim": 64,
    "edge_feature_dim": 64,
    "hidden_dim": 64,
    "mpnn_layers": 6,
    "dropout": 0.1,
    "out_dim": 1,
    "pooling": "sum",
    "subgraph_sampling": true,
    "subgraph_param": { "k": 10, "m": 32, "pooling": "mean" },
    "kwargs": {
      "mlp_layers": 2
    }
  },

  "train": {
    "epochs": 100,
    "train_batch_size": 128,
    "val_batch_size": 256,
    "lr": 1e-3,
    "weight_decay": 1e-5,
    "optimizer": "adam",
    "scheduler": {
      "type": "reduce_on_plateau",
      "patience": 15,
      "factor": 0.5
    },
    "loss_fn": "BCEWithLogitsLoss",
    "metric": "ROCAUC",
    "grad_clip": 1.0
  },

  "device": "cuda",
  "seed": 42,
  "num_workers": 4,
  "save_every": 10,
  "keep_last_k": 3,
  "sampler": "graphlet"
}
